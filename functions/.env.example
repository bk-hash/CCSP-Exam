# Firebase Functions Environment Variables
# Copy this file to .env and add your actual values

# AI Provider Selection
# Choose 'openai' for standard OpenAI API or 'azure' for Azure OpenAI Service
AI_PROVIDER=openai

# Standard OpenAI Configuration (when AI_PROVIDER=openai)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Azure OpenAI Configuration (when AI_PROVIDER=azure)
# Get these from your Azure OpenAI resource in Azure Portal
# See AZURE_OPENAI_INTEGRATION.md for detailed setup instructions
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Node Environment
NODE_ENV=production
