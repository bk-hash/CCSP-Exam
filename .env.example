# Google OAuth Configuration
# Copy this file to .env and replace with your actual Google Client ID

# Replace with your actual Google Client ID from Google Cloud Console
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Development bypass (set to true to skip authentication during development)
# Remove or set to false for production
REACT_APP_BYPASS_AUTH=false

# Instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing project  
# 3. Enable Google Identity API
# 4. Create OAuth 2.0 client credentials
# 5. Add your domain to authorized origins:
#    - http://localhost:3000 (development)
#    - http://localhost:3001 (development)
#    - https://yourusername.github.io (production)
# 6. Replace the client ID above with your actual client ID
# 7. Copy this file to .env (without .example)

# Troubleshooting:
# If you get "flowName=GeneralOAuthFlow" error, see OAUTH_TROUBLESHOOTING.md

# =============================================================================
# AI Assistant Configuration (Optional)
# =============================================================================

# Choose your AI provider: 'openai', 'anthropic', 'google', or 'azure'
REACT_APP_AI_PROVIDER=openai

# Add your AI API key here
# Get your API key from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/settings/keys
# - Google AI: https://makersuite.google.com/app/apikey
# - Azure: Your Azure OpenAI endpoint

REACT_APP_AI_API_KEY=your_api_key_here

# For Azure OpenAI only - add your deployment endpoint
# REACT_APP_AZURE_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview

# Optional: Choose specific model (defaults are set in aiService.js)
# REACT_APP_AI_MODEL=gpt-4

# Note: The AI assistant will work without configuration, but will show a setup message
# See AI_ASSISTANT_SETUP.md for detailed setup instructions
