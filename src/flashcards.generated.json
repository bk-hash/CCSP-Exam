const fs = require('fs');

const domains = [
  "Cloud Concepts, Architecture and Design",
  "Cloud Data Security",
  "Cloud Platform and Infrastructure Security",
  "Cloud Application Security",
  "Cloud Security Operations",
  "Legal, Risk, and Compliance"
];

// Example flashcard templates (customize these for real content)
const templates = [
  {
    term: "{domain} - Key Term",
    definition: "Definition or explanation for the key term in {domain}."
  },
  {
    term: "{domain} - Important Standard",
    definition: "Summary of an important standard or framework in {domain}."
  },
  {
    term: "{domain} - Process",
    definition: "Description of a critical process in {domain}."
  },
  {
    term: "{domain} - Acronym",
    definition: "What the acronym stands for and its relevance in {domain}."
  }
];

let flashcards = [];

domains.forEach(domain => {
  // Generate ~20 flashcards per domain (adjust as needed)
  for (let i = 0; i < 20; i++) {
    const template = templates[i % templates.length];
    flashcards.push({
      domain,
      term: template.term.replace("{domain}", domain),
      definition: template.definition.replace("{domain}", domain)
    });
  }
});

fs.writeFileSync('flashcards.generated.json', JSON.stringify(flashcards, null, 2));
